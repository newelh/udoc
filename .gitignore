# Python venvs, uv, and build artifacts
.venv/
__pycache__/
*.egg-info/
dist/
# Maturin-installed cdylib next to the python source tree.
python/udoc/_native*.so
python/udoc/*.abi3.so
python/udoc/*.so
python/udoc/*.pyd
python/udoc/*.dylib
# Bundled CLI binary lives at python/udoc/_bin/udoc (staged into wheels
# by build-wheels.sh / release CI). NOT git-ignored -- maturin respects
# .gitignore when packing python-source files into the wheel, so an
# entry here would silently drop the binary from every wheel build.
# Devs should leave the file untracked locally.

