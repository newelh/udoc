_udoc() {
    local i cur prev opts cmd
    COMPREPLY=()
    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        cur="$2"
    else
        cur="${COMP_WORDS[COMP_CWORD]}"
    fi
    prev="$3"
    cmd=""
    opts=""

    for i in "${COMP_WORDS[@]:0:COMP_CWORD}"
    do
        case "${cmd},${i}" in
            ",$1")
                cmd="udoc"
                ;;
            udoc,completions)
                cmd="udoc__subcmd__completions"
                ;;
            udoc,extract)
                cmd="udoc__subcmd__extract"
                ;;
            udoc,features)
                cmd="udoc__subcmd__features"
                ;;
            udoc,fonts)
                cmd="udoc__subcmd__fonts"
                ;;
            udoc,help)
                cmd="udoc__subcmd__help"
                ;;
            udoc,images)
                cmd="udoc__subcmd__images"
                ;;
            udoc,inspect)
                cmd="udoc__subcmd__inspect"
                ;;
            udoc,mangen)
                cmd="udoc__subcmd__mangen"
                ;;
            udoc,metadata)
                cmd="udoc__subcmd__metadata"
                ;;
            udoc,render)
                cmd="udoc__subcmd__render"
                ;;
            udoc,tables)
                cmd="udoc__subcmd__tables"
                ;;
            udoc__subcmd__help,completions)
                cmd="udoc__subcmd__help__subcmd__completions"
                ;;
            udoc__subcmd__help,extract)
                cmd="udoc__subcmd__help__subcmd__extract"
                ;;
            udoc__subcmd__help,features)
                cmd="udoc__subcmd__help__subcmd__features"
                ;;
            udoc__subcmd__help,fonts)
                cmd="udoc__subcmd__help__subcmd__fonts"
                ;;
            udoc__subcmd__help,help)
                cmd="udoc__subcmd__help__subcmd__help"
                ;;
            udoc__subcmd__help,images)
                cmd="udoc__subcmd__help__subcmd__images"
                ;;
            udoc__subcmd__help,inspect)
                cmd="udoc__subcmd__help__subcmd__inspect"
                ;;
            udoc__subcmd__help,mangen)
                cmd="udoc__subcmd__help__subcmd__mangen"
                ;;
            udoc__subcmd__help,metadata)
                cmd="udoc__subcmd__help__subcmd__metadata"
                ;;
            udoc__subcmd__help,render)
                cmd="udoc__subcmd__help__subcmd__render"
                ;;
            udoc__subcmd__help,tables)
                cmd="udoc__subcmd__help__subcmd__tables"
                ;;
            *)
                ;;
        esac
    done

    case "${cmd}" in
        udoc)
            opts="-O -p -F -o -q -v -h -V --out --chunk-by --chunk-size --pages --input-format --password --ocr --hook --ocr-all --hook-image-dir --hook-timeout --max-file-size --max-pages --no-tables --no-images --no-presentation --raw-spans --pretty --output --image-dir --quiet --verbose --errors --jobs --processes --help --version [FILES]... extract render fonts tables inspect images metadata completions mangen features help"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 1 ]] ; then
                COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
                return 0
            fi
            case "${prev}" in
                --out)
                    COMPREPLY=($(compgen -W "text json jsonl tsv markdown chunks" -- "${cur}"))
                    return 0
                    ;;
                -O)
                    COMPREPLY=($(compgen -W "text json jsonl tsv markdown chunks" -- "${cur}"))
                    return 0
                    ;;
                --chunk-by)
                    COMPREPLY=($(compgen -W "page heading section size" -- "${cur}"))
                    return 0
                    ;;
                --chunk-size)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --pages)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                -p)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --input-format)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                -F)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --password)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --ocr)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --hook)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --hook-image-dir)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --hook-timeout)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --max-file-size)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --max-pages)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --output)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                -o)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --image-dir)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --errors)
                    COMPREPLY=($(compgen -W "human json" -- "${cur}"))
                    return 0
                    ;;
                --jobs)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --processes)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                *)
                    COMPREPLY=()
                    ;;
            esac
            COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
            return 0
            ;;
        udoc__subcmd__completions)
            opts="-h --help bash elvish fish powershell zsh"
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 2 ]] ; then
                COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
                return 0
            fi
            case "${prev}" in
                *)
                    COMPREPLY=()
                    ;;
            esac
            COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
            return 0
            ;;
        udoc__subcmd__extract)
            opts="-O -p -F -o -q -v -h --out --chunk-by --chunk-size --pages --input-format --password --ocr --hook --ocr-all --hook-image-dir --hook-timeout --max-file-size --max-pages --no-tables --no-images --no-presentation --raw-spans --pretty --output --image-dir --quiet --verbose --errors --jobs --processes --help [FILES]..."
            if [[ ${cur} == -* || ${COMP_CWORD} -eq 2 ]] ; then
                COMPREPLY=( $(compgen -W "${opts}" -- "${cur}") )
                return 0
            fi
            case "${prev}" in
                --out)
                    COMPREPLY=($(compgen -W "text json jsonl tsv markdown chunks" -- "${cur}"))
                    return 0
                    ;;
                -O)
                    COMPREPLY=($(compgen -W "text json jsonl tsv markdown chunks" -- "${cur}"))
                    return 0
                    ;;
                --chunk-by)
                    COMPREPLY=($(compgen -W "page heading section size" -- "${cur}"))
                    return 0
                    ;;
                --chunk-size)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --pages)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                -p)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
                --input-format)
                    COMPREPLY=($(compgen -f "${cur}"))
                    return 0
                    ;;
