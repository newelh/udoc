if [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 4 || "${BASH_VERSINFO[0]}" -gt 4 ]]; then
    complete -F _udoc -o nosort -o bashdefault -o default udoc
else
    complete -F _udoc -o bashdefault -o default udoc
fi
