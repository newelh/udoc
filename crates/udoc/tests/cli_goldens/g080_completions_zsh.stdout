#compdef udoc

autoload -U is-at-least

_udoc() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-O+[Output mode (text|json|jsonl|tsv|markdown|chunks). Default \`text\`]:MODE:((text\:"Plain text (default)"
json\:"Full document JSON"
jsonl\:"Streaming JSON Lines, one record per page"
tsv\:"Tables only, tab-separated values"
markdown\:"LLM-friendly markdown with citation anchors"
chunks\:"Chunked NDJSON for ingest pipelines (requires \`--chunk-by\`)"))' \
'--out=[Output mode (text|json|jsonl|tsv|markdown|chunks). Default \`text\`]:MODE:((text\:"Plain text (default)"
json\:"Full document JSON"
jsonl\:"Streaming JSON Lines, one record per page"
tsv\:"Tables only, tab-separated values"
markdown\:"LLM-friendly markdown with citation anchors"
chunks\:"Chunked NDJSON for ingest pipelines (requires \`--chunk-by\`)"))' \
'--chunk-by=[Chunk strategy when \`--out chunks\` (page|heading|section|size)]:STRATEGY:((page\:"One chunk per page"
heading\:"One chunk per Block\:\:Heading boundary"
section\:"One chunk per top-level (rank-1) heading boundary"
size\:"Target N chars per chunk; never split a paragraph"))' \
'--chunk-size=[Chunk size in chars when \`--chunk-by size\` (default 2000)]:CHUNK_SIZE:_default' \
'-p+[Page range (e.g., "1-5", "3,7,9-12")]:PAGES:_default' \
'--pages=[Page range (e.g., "1-5", "3,7,9-12")]:PAGES:_default' \
'-F+[Force input format (pdf, docx, xlsx, pptx, doc, xls, ppt, odt, ods, odp, rtf, md). Renamed from \`--format\` to disambiguate from \`--out\`]:INPUT_FORMAT:_default' \
'--input-format=[Force input format (pdf, docx, xlsx, pptx, doc, xls, ppt, odt, ods, odp, rtf, md). Renamed from \`--format\` to disambiguate from \`--out\`]:INPUT_FORMAT:_default' \
'--password=[Document password (encrypted PDF)]:PASSWORD:_default' \
'--ocr=[OCR hook command]:OCR:_default' \
'*--hook=[Post-processing hook (repeatable)]:HOOK:_default' \
'--hook-image-dir=[Directory for page images passed to hooks]:HOOK_IMAGE_DIR:_files' \
'--hook-timeout=[Per-page hook timeout in seconds (default\: 60)]:HOOK_TIMEOUT:_default' \
'--max-file-size=[Maximum file size (e.g., "256mb", "1gb", "4096")]:MAX_FILE_SIZE:_default' \
'--max-pages=[Maximum pages/sheets/slides to extract]:MAX_PAGES:_default' \
'-o+[Output file (default\: stdout)]:OUTPUT:_files' \
'--output=[Output file (default\: stdout)]:OUTPUT:_files' \
'--image-dir=[Output directory for \`--out chunks\` images / \`images\` subcommand dumps (default\: current directory)]:IMAGE_DIR:_files' \
'--errors=[Error output format on stderr\: \`human\` (default) or \`json\`. The JSON form emits one object per line (\`{"code","message","context"}\`) so agents grep-ing under \`2>&1\` can recover the structured error without parsing the human prose. The error-code strings are part of the agent contract]:FORMAT:((human\:"Human-readable lines\: \`udoc\: <message>\`. Default"
json\:"One JSON object per line on stderr\: \`{"code"\:"E_FORMAT_UNSUPPORTED","message"\:"...","context"\:"..."}\`"))' \
'(--processes)--jobs=[Number of parallel in-process extraction threads]:JOBS:_default' \
'(--jobs)--processes=[Number of subprocess workers for batch extraction]:PROCESSES:_default' \
'--ocr-all[OCR all pages, not just textless ones]' \
'--no-tables[Skip table detection (PDF only, ~16% faster)]' \
'--no-images[Skip image extraction (PDF only, ~19% faster). Disables in-parser image decoding entirely. Use \`udoc images <file>\` (subcommand) when you want to dump embedded images]' \
'--no-presentation[Omit presentation overlay from JSON/JSONL]' \
'--raw-spans[Include raw positioned spans in JSON output]' \
'--pretty[Pretty-print JSON output]' \
'-q[No-op kept for backwards compatibility. udoc is silent on stderr by default; \`--quiet\` is implicit. Pass \`-v\` to opt back in]' \
'--quiet[No-op kept for backwards compatibility. udoc is silent on stderr by default; \`--quiet\` is implicit. Pass \`-v\` to opt back in]' \
'*-v[Show diagnostic warnings on stderr. Pass \`-v\` once for warnings (font fallbacks, recovered xref, table-detection skips), \`-vv\` for warnings + info-level progress (per-font ToUnicode loads, per-page reading-order tier). Repeated identical messages are deduplicated]' \
'*--verbose[Show diagnostic warnings on stderr. Pass \`-v\` once for warnings (font fallbacks, recovered xref, table-detection skips), \`-vv\` for warnings + info-level progress (per-font ToUnicode loads, per-page reading-order tier). Repeated identical messages are deduplicated]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::files -- Document path(s). Use - for stdin. Multiple files for batch extraction:_default' \
":: :_udoc_commands" \
"*::: :->udoc" \
&& ret=0
    case $state in
    (udoc)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:udoc-command-$line[2]:"
        case $line[2] in
            (extract)
_arguments "${_arguments_options[@]}" : \
'-O+[Output mode (text|json|jsonl|tsv|markdown|chunks). Default \`text\`]:MODE:((text\:"Plain text (default)"
json\:"Full document JSON"
jsonl\:"Streaming JSON Lines, one record per page"
tsv\:"Tables only, tab-separated values"
markdown\:"LLM-friendly markdown with citation anchors"
chunks\:"Chunked NDJSON for ingest pipelines (requires \`--chunk-by\`)"))' \
'--out=[Output mode (text|json|jsonl|tsv|markdown|chunks). Default \`text\`]:MODE:((text\:"Plain text (default)"
json\:"Full document JSON"
jsonl\:"Streaming JSON Lines, one record per page"
tsv\:"Tables only, tab-separated values"
markdown\:"LLM-friendly markdown with citation anchors"
chunks\:"Chunked NDJSON for ingest pipelines (requires \`--chunk-by\`)"))' \
'--chunk-by=[Chunk strategy when \`--out chunks\` (page|heading|section|size)]:STRATEGY:((page\:"One chunk per page"
heading\:"One chunk per Block\:\:Heading boundary"
section\:"One chunk per top-level (rank-1) heading boundary"
size\:"Target N chars per chunk; never split a paragraph"))' \
'--chunk-size=[Chunk size in chars when \`--chunk-by size\` (default 2000)]:CHUNK_SIZE:_default' \
'-p+[Page range (e.g., "1-5", "3,7,9-12")]:PAGES:_default' \
'--pages=[Page range (e.g., "1-5", "3,7,9-12")]:PAGES:_default' \
'-F+[Force input format (pdf, docx, xlsx, pptx, doc, xls, ppt, odt, ods, odp, rtf, md). Renamed from \`--format\` to disambiguate from \`--out\`]:INPUT_FORMAT:_default' \
'--input-format=[Force input format (pdf, docx, xlsx, pptx, doc, xls, ppt, odt, ods, odp, rtf, md). Renamed from \`--format\` to disambiguate from \`--out\`]:INPUT_FORMAT:_default' \
'--password=[Document password (encrypted PDF)]:PASSWORD:_default' \
'--ocr=[OCR hook command]:OCR:_default' \
'*--hook=[Post-processing hook (repeatable)]:HOOK:_default' \
'--hook-image-dir=[Directory for page images passed to hooks]:HOOK_IMAGE_DIR:_files' \
'--hook-timeout=[Per-page hook timeout in seconds (default\: 60)]:HOOK_TIMEOUT:_default' \
'--max-file-size=[Maximum file size (e.g., "256mb", "1gb", "4096")]:MAX_FILE_SIZE:_default' \
'--max-pages=[Maximum pages/sheets/slides to extract]:MAX_PAGES:_default' \
'-o+[Output file (default\: stdout)]:OUTPUT:_files' \
'--output=[Output file (default\: stdout)]:OUTPUT:_files' \
'--image-dir=[Output directory for \`--out chunks\` images / \`images\` subcommand dumps (default\: current directory)]:IMAGE_DIR:_files' \
'--errors=[Error output format on stderr\: \`human\` (default) or \`json\`. The JSON form emits one object per line (\`{"code","message","context"}\`) so agents grep-ing under \`2>&1\` can recover the structured error without parsing the human prose. The error-code strings are part of the agent contract]:FORMAT:((human\:"Human-readable lines\: \`udoc\: <message>\`. Default"
json\:"One JSON object per line on stderr\: \`{"code"\:"E_FORMAT_UNSUPPORTED","message"\:"...","context"\:"..."}\`"))' \
'(--processes)--jobs=[Number of parallel in-process extraction threads]:JOBS:_default' \
'(--jobs)--processes=[Number of subprocess workers for batch extraction]:PROCESSES:_default' \
'--ocr-all[OCR all pages, not just textless ones]' \
'--no-tables[Skip table detection (PDF only, ~16% faster)]' \
'--no-images[Skip image extraction (PDF only, ~19% faster). Disables in-parser image decoding entirely. Use \`udoc images <file>\` (subcommand) when you want to dump embedded images]' \
'--no-presentation[Omit presentation overlay from JSON/JSONL]' \
'--raw-spans[Include raw positioned spans in JSON output]' \
'--pretty[Pretty-print JSON output]' \
'-q[No-op kept for backwards compatibility. udoc is silent on stderr by default; \`--quiet\` is implicit. Pass \`-v\` to opt back in]' \
'--quiet[No-op kept for backwards compatibility. udoc is silent on stderr by default; \`--quiet\` is implicit. Pass \`-v\` to opt back in]' \
'*-v[Show diagnostic warnings on stderr. Pass \`-v\` once for warnings (font fallbacks, recovered xref, table-detection skips), \`-vv\` for warnings + info-level progress (per-font ToUnicode loads, per-page reading-order tier). Repeated identical messages are deduplicated]' \
'*--verbose[Show diagnostic warnings on stderr. Pass \`-v\` once for warnings (font fallbacks, recovered xref, table-detection skips), \`-vv\` for warnings + info-level progress (per-font ToUnicode loads, per-page reading-order tier). Repeated identical messages are deduplicated]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::files -- Document path(s). Use - for stdin. Multiple files for batch extraction:_default' \
&& ret=0
;;
(render)
_arguments "${_arguments_options[@]}" : \
'-o+[Output directory. Created if missing]:DIR:_files' \
'--output=[Output directory. Created if missing]:DIR:_files' \
'-p+[Page range (e.g. "1-5", "3,7,9-12"). Renders every page when omitted]:PAGES:_default' \
'--pages=[Page range (e.g. "1-5", "3,7,9-12"). Renders every page when omitted]:PAGES:_default' \
'--dpi=[Render DPI]:DPI:_default' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Input document:_files' \
&& ret=0
;;
(fonts)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the report here instead of stdout]:FILE:_files' \
'--output=[Write the report here instead of stdout]:FILE:_files' \
'--format=[Output format\: \`json\` (default) or \`text\`]:FORMAT:_default' \
'--trace[Emit the per-font routing chain (subset-prefix strip, tier1 name match, Unicode sniff, fallback reason, final resolution) alongside each entry. Useful when auditing why a specific font ended up substituted. Ignored under \`--audit\`]' \
'--audit[Run the full corpus-style font-resolution audit (replaces the \`audit-fonts\` subcommand). Slower; emits more detail]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':file -- Input document:_files' \
&& ret=0
;;
(tables)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the report here instead of stdout]:FILE:_files' \
'--output=[Write the report here instead of stdout]:FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Input document:_files' \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
'--full[Force a complete scan instead of the default sampled mode. Sampled mode looks at 5 pages spread across the document; \`--full\` walks every page]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':file -- Input document:_files' \
&& ret=0
;;
(images)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the listing here instead of stdout]:FILE:_files' \
'--output=[Write the listing here instead of stdout]:FILE:_files' \
'--format=[Listing format\: \`json\` (default) or \`text\`]:FORMAT:_default' \
'--extract=[Dump each image to this directory]:DIR:_files' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Input document:_files' \
&& ret=0
;;
(metadata)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the report here instead of stdout]:FILE:_files' \
'--output=[Write the report here instead of stdout]:FILE:_files' \
'--format=[Output format\: \`json\` (default) or \`text\`]:FORMAT:_default' \
'-h[Print help]' \
'--help[Print help]' \
':file -- Input document:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell\: bash, zsh, fish, elvish, powershell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(mangen)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(features)
_arguments "${_arguments_options[@]}" : \
'-o+[Write the report here instead of stdout]:FILE:_files' \
'--output=[Write the report here instead of stdout]:FILE:_files' \
'--format=[Output format\: \`text\` (default) or \`json\`]:FORMAT:_default' \
'(--format)--json[Deprecated shortcut for \`--format json\`. Hidden from --help; still honoured for scripts that picked it up before \`--format\` landed. Prefer \`--format json\` in new code]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_udoc__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:udoc-help-command-$line[1]:"
        case $line[1] in
            (extract)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(render)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(fonts)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(tables)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(images)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(metadata)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(mangen)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(features)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_udoc_commands] )) ||
_udoc_commands() {
    local commands; commands=(
'extract:Extract text, tables, images, and metadata from a document. Same behaviour as the bare-file invocation; kept as an explicit subcommand for scripts that prefer unambiguous CLI shapes' \
'render:Render document pages to PNG images on disk' \
'fonts:List fonts referenced by a document with their FontResolution (Exact / Substituted / SyntheticFallback)' \
'tables:Extract tables only, defaulting to TSV. Equivalent to \`udoc extract --out tsv <file>\`; the subcommand is the discoverability win for users who already know they want tables' \
'inspect:Quickly probe a document for shape signals (format, page count, has-text, likely-scanned, has-tables, has-encryption, font resolution counts) without doing a full extraction' \
'images:List images embedded in a document (filter, dimensions, bits-per-component, byte size). With \`--extract\`, dump each image to disk using the native format'\''s file extension' \
'metadata:Emit structured document metadata as JSON (title, author, creator, producer, creation/modification dates, page count, and extended properties)' \
'completions:Emit a shell completion script on stdout. Hidden from the top-level \`--help\` listing; reachable via \`udoc completions --help\`' \
'mangen:Emit a roff-formatted man page for \`udoc(1)\` on stdout. Redirect into your \`man\` path or pipe through \`man -l -\` to read. Hidden from the top-level \`--help\` listing' \
'features:Print the compile-time feature report for this \`udoc\` binary (tier1 font bundles, CJK fallback, own JBIG2 decoder, etc.). Operators use this to confirm "why did feature X not fire?" maps to "the binary was built without -F X" vs a runtime misconfig' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'udoc commands' commands "$@"
}
(( $+functions[_udoc__subcmd__completions_commands] )) ||
_udoc__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'udoc completions commands' commands "$@"
}
(( $+functions[_udoc__subcmd__extract_commands] )) ||
_udoc__subcmd__extract_commands() {
    local commands; commands=()
    _describe -t commands 'udoc extract commands' commands "$@"
}
(( $+functions[_udoc__subcmd__features_commands] )) ||
_udoc__subcmd__features_commands() {
    local commands; commands=()
    _describe -t commands 'udoc features commands' commands "$@"
}
(( $+functions[_udoc__subcmd__fonts_commands] )) ||
_udoc__subcmd__fonts_commands() {
    local commands; commands=()
    _describe -t commands 'udoc fonts commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help_commands] )) ||
_udoc__subcmd__help_commands() {
    local commands; commands=(
'extract:Extract text, tables, images, and metadata from a document. Same behaviour as the bare-file invocation; kept as an explicit subcommand for scripts that prefer unambiguous CLI shapes' \
'render:Render document pages to PNG images on disk' \
'fonts:List fonts referenced by a document with their FontResolution (Exact / Substituted / SyntheticFallback)' \
'tables:Extract tables only, defaulting to TSV. Equivalent to \`udoc extract --out tsv <file>\`; the subcommand is the discoverability win for users who already know they want tables' \
'inspect:Quickly probe a document for shape signals (format, page count, has-text, likely-scanned, has-tables, has-encryption, font resolution counts) without doing a full extraction' \
'images:List images embedded in a document (filter, dimensions, bits-per-component, byte size). With \`--extract\`, dump each image to disk using the native format'\''s file extension' \
'metadata:Emit structured document metadata as JSON (title, author, creator, producer, creation/modification dates, page count, and extended properties)' \
'completions:Emit a shell completion script on stdout. Hidden from the top-level \`--help\` listing; reachable via \`udoc completions --help\`' \
'mangen:Emit a roff-formatted man page for \`udoc(1)\` on stdout. Redirect into your \`man\` path or pipe through \`man -l -\` to read. Hidden from the top-level \`--help\` listing' \
'features:Print the compile-time feature report for this \`udoc\` binary (tier1 font bundles, CJK fallback, own JBIG2 decoder, etc.). Operators use this to confirm "why did feature X not fire?" maps to "the binary was built without -F X" vs a runtime misconfig' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'udoc help commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__completions_commands] )) ||
_udoc__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help completions commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__extract_commands] )) ||
_udoc__subcmd__help__subcmd__extract_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help extract commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__features_commands] )) ||
_udoc__subcmd__help__subcmd__features_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help features commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__fonts_commands] )) ||
_udoc__subcmd__help__subcmd__fonts_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help fonts commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__help_commands] )) ||
_udoc__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help help commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__images_commands] )) ||
_udoc__subcmd__help__subcmd__images_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help images commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__inspect_commands] )) ||
_udoc__subcmd__help__subcmd__inspect_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help inspect commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__mangen_commands] )) ||
_udoc__subcmd__help__subcmd__mangen_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help mangen commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__metadata_commands] )) ||
_udoc__subcmd__help__subcmd__metadata_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help metadata commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__render_commands] )) ||
_udoc__subcmd__help__subcmd__render_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help render commands' commands "$@"
}
(( $+functions[_udoc__subcmd__help__subcmd__tables_commands] )) ||
_udoc__subcmd__help__subcmd__tables_commands() {
    local commands; commands=()
    _describe -t commands 'udoc help tables commands' commands "$@"
}
(( $+functions[_udoc__subcmd__images_commands] )) ||
_udoc__subcmd__images_commands() {
    local commands; commands=()
    _describe -t commands 'udoc images commands' commands "$@"
}
(( $+functions[_udoc__subcmd__inspect_commands] )) ||
_udoc__subcmd__inspect_commands() {
    local commands; commands=()
    _describe -t commands 'udoc inspect commands' commands "$@"
}
(( $+functions[_udoc__subcmd__mangen_commands] )) ||
_udoc__subcmd__mangen_commands() {
    local commands; commands=()
    _describe -t commands 'udoc mangen commands' commands "$@"
}
(( $+functions[_udoc__subcmd__metadata_commands] )) ||
_udoc__subcmd__metadata_commands() {
    local commands; commands=()
    _describe -t commands 'udoc metadata commands' commands "$@"
}
(( $+functions[_udoc__subcmd__render_commands] )) ||
_udoc__subcmd__render_commands() {
    local commands; commands=()
    _describe -t commands 'udoc render commands' commands "$@"
}
(( $+functions[_udoc__subcmd__tables_commands] )) ||
_udoc__subcmd__tables_commands() {
    local commands; commands=()
    _describe -t commands 'udoc tables commands' commands "$@"
}

if [ "$funcstack[1]" = "_udoc" ]; then
    _udoc "$@"
else
    compdef _udoc udoc
fi
